{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "capnweb-dynamic-capabilities-example",
  "main": "src/worker.ts",
  "compatibility_date": "2026-06-18",
  "durable_objects": {
    "bindings": [
      {
        "name": "CAP_STORE",
        "class_name": "CapabilityStore"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CapabilityStore"]
    }
  ]
}
